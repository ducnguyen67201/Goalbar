{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Goalbar",
  "version": "0.1.0",
  "identifier": "com.ducnguyen.goalbar",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Goalbar",
        "width": 1360,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; connect-src 'self' ipc: http://ipc.localhost https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local growth operating system for solo founders",
    "longDescription": "Discover your ICP, operate founder channels, and learn from every experiment without giving up control of your data.",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": ["https://github.com/ducnguyen67201/Goalbar/releases/latest/download/latest.json"]
    }
  }
}
